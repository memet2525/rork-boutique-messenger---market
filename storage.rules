rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "atlaspelet.com@gmail.com";
    }

    function isDelete() {
      return request.resource == null;
    }

    function hasImageContentType() {
      return request.resource != null
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');
    }

    function isWithinSizeLimit(maxBytes) {
      return request.resource != null
        && request.resource.size != null
        && request.resource.size <= maxBytes;
    }

    function isValidImageWrite(maxBytes) {
      return isDelete()
        || (
          hasImageContentType()
          && isWithinSizeLimit(maxBytes)
        );
    }

    function isOwnAvatar(fileName) {
      return isSignedIn()
        && fileName.matches('^' + request.auth.uid + '_.*$');
    }

    function canManageStoreFolder(storeId) {
      return isSignedIn()
        && (
          isSuperAdmin()
          || request.auth.uid == storeId
        );
    }

    match /avatars/{fileName} {
      allow read: if true;
      allow write: if (isSuperAdmin() || isOwnAvatar(fileName))
        && isValidImageWrite(5 * 1024 * 1024);
    }

    match /products/{storeId}/{fileName} {
      allow read: if true;
      allow write: if canManageStoreFolder(storeId)
        && isValidImageWrite(10 * 1024 * 1024);
    }

    match /stores/{storeId}/{allPaths=**} {
      allow read: if true;
      allow write: if canManageStoreFolder(storeId)
        && isValidImageWrite(10 * 1024 * 1024);
    }

    match /chats/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && isValidImageWrite(10 * 1024 * 1024);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
