rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "atlaspelet.com@gmail.com";
    }

    function hasImageContentType() {
      return request.resource != null
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');
    }

    function isUnderSizeLimit(maxBytes) {
      return request.resource != null
        && request.resource.size != null
        && request.resource.size < maxBytes;
    }

    function isDelete() {
      return request.resource == null;
    }

    function isValidImageUpload(maxBytes) {
      return request.resource != null
        && hasImageContentType()
        && isUnderSizeLimit(maxBytes);
    }

    function isOwnAvatarFile(fileName) {
      return isSignedIn()
        && fileName.matches('^' + request.auth.uid + '_.*');
    }

    function canWriteStoreFolder(storeId) {
      return isSignedIn()
        && (
          isSuperAdmin()
          || request.auth.uid == storeId
        );
    }

    match /avatars/{fileName} {
      allow read: if true;
      allow write: if (
          isSuperAdmin()
          || isOwnAvatarFile(fileName)
        )
        && (
          isDelete()
          || isValidImageUpload(5 * 1024 * 1024)
        );
    }

    match /products/{storeId}/{allPaths=**} {
      allow read: if true;
      allow write: if canWriteStoreFolder(storeId)
        && (
          isDelete()
          || isValidImageUpload(10 * 1024 * 1024)
        );
    }

    match /stores/{storeId}/{allPaths=**} {
      allow read: if true;
      allow write: if canWriteStoreFolder(storeId)
        && (
          isDelete()
          || isValidImageUpload(10 * 1024 * 1024)
        );
    }

    match /chats/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && (
          isDelete()
          || isValidImageUpload(10 * 1024 * 1024)
        );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
