rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "atlaspelet.com@gmail.com";
    }

    function userNotificationOnlyUpdate() {
      return isSuperAdmin()
        && resource != null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["systemNotifications", "updatedAt"]);
    }

    function isParticipant() {
      return isSignedIn()
        && (
          resource == null
          || isSuperAdmin()
          || request.auth.uid in resource.data.participants
        );
    }

    function canReadChatById(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId));
      return isSignedIn()
        && chat != null
        && (
          isSuperAdmin()
          || request.auth.uid in chat.data.participants
        );
    }

    function chatIdentityUnchanged() {
      return request.resource.data.participants == resource.data.participants
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.storeOwnerId == resource.data.storeOwnerId
        && request.resource.data.customerId == resource.data.customerId;
    }

    function validChatCreate(chatId) {
      return isSignedIn()
        && request.resource.data.keys().hasAll([
          "participants",
          "storeId",
          "storeName",
          "storeAvatar",
          "storeOwnerId",
          "customerId",
          "customerName",
          "customerAvatar"
        ])
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && (
          isSuperAdmin()
          || request.auth.uid in request.resource.data.participants
        )
        && (
          isSuperAdmin()
          || request.resource.data.customerId == request.auth.uid
          || request.resource.data.storeOwnerId == request.auth.uid
          || chatId == "admin_" + request.auth.uid
        );
    }

    function validMessageCreate(chatId, messageId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId));
      return isSignedIn()
        && chat != null
        && request.resource.data.id == messageId
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 5000
        && request.resource.data.senderId is string
        && request.resource.data.timestamp is string
        && request.resource.data.createdAt != null
        && request.resource.data.isRead is bool
        && (
          isSuperAdmin()
          || request.resource.data.senderId == request.auth.uid
          || (
            chat.data.customerId == request.auth.uid
            && chatId == "admin_" + chat.data.customerId
            && request.resource.data.senderId == "butikbiz_admin"
          )
        )
        && (
          isSuperAdmin()
          || request.auth.uid in chat.data.participants
        );
    }

    function validAddressCreate(addressId) {
      return isSignedIn()
        && request.resource.data.id == addressId
        && request.resource.data.storeId is string
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() >= 2
        && request.resource.data.customerName.size() <= 120
        && request.resource.data.customerPhone is string
        && request.resource.data.customerPhone.size() >= 5
        && request.resource.data.customerPhone.size() <= 30
        && request.resource.data.city is string
        && request.resource.data.city.size() >= 2
        && request.resource.data.city.size() <= 80
        && request.resource.data.district is string
        && request.resource.data.district.size() >= 2
        && request.resource.data.district.size() <= 80
        && request.resource.data.addressLine is string
        && request.resource.data.addressLine.size() >= 5
        && request.resource.data.addressLine.size() <= 500
        && request.resource.data.note is string
        && request.resource.data.note.size() <= 1000
        && request.resource.data.createdAt != null;
    }

    match /users/{uid} {
      allow read: if isSignedIn();

      allow create: if isSuperAdmin()
        || (
          isOwner(uid)
          && request.resource.data.uid == uid
        );

      allow update: if isSuperAdmin()
        || (
          isOwner(uid)
          && request.resource.data.uid == uid
        )
        || userNotificationOnlyUpdate();

      allow delete: if isSuperAdmin();
    }

    match /stores/{storeId} {
      allow read: if true;

      allow create: if isSuperAdmin()
        || (
          isOwner(storeId)
          && request.resource.data.ownerId == storeId
        );

      allow update, delete: if isSuperAdmin() || isOwner(storeId);

      match /products/{productId} {
        allow read: if true;
        allow create, update, delete: if isSuperAdmin() || isOwner(storeId);
      }

      match /addresses/{addressId} {
        allow create: if validAddressCreate(addressId);
        allow read, delete: if isSuperAdmin() || isOwner(storeId);
        allow update: if false;
      }
    }

    match /chats/{chatId} {
      allow read: if isSignedIn()
        && (
          resource == null
          || isSuperAdmin()
          || request.auth.uid in resource.data.participants
        );
      allow create: if validChatCreate(chatId);
      allow update: if isSignedIn()
        && resource != null
        && (
          isSuperAdmin()
          || request.auth.uid in resource.data.participants
          || request.auth.uid in request.resource.data.participants
        )
        && (
          isSuperAdmin()
          || chatIdentityUnchanged()
        );
      allow delete: if isSuperAdmin();

      match /messages/{messageId} {
        allow read: if canReadChatById(chatId);
        allow create: if validMessageCreate(chatId, messageId);
        allow update: if canReadChatById(chatId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isRead"]);
        allow delete: if canReadChatById(chatId);
      }
    }

    match /admin/{docId} {
      allow read: if docId == "settings" ? true : isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    match /adminMembers/{uid} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || isOwner(uid);
    }

    match /adminStores/{storeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin() || isOwner(storeId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
