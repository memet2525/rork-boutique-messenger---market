rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcı profilleri
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Mağazalar - herkes okuyabilir, sadece mağaza sahibi yazabilir
    match /stores/{storeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == storeId;

      // Adres gönderimleri - herkes oluşturabilir, sadece mağaza sahibi okuyabilir/silebilir
      match /addresses/{addressId} {
        allow read: if request.auth != null && request.auth.uid == storeId;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == storeId;
      }
    }

    // Sohbetler - sadece katılımcılar erişebilir
    match /chats/{chatId} {
      allow read: if request.auth != null &&
        (request.auth.uid in resource.data.participants ||
         chatId.matches('admin_' + request.auth.uid));
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      // Mesajlar - sohbet katılımcıları erişebilir
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
      }
    }

    // Admin verileri
    match /admin/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
