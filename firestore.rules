rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Mağazalar - herkes okuyabilir, sadece mağaza sahibi yazabilir
    match /stores/{storeId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.auth.uid == storeId;
      allow update: if request.auth != null
        && request.auth.uid == storeId;
      allow delete: if request.auth != null
        && request.auth.uid == storeId;

      // Ürünler (subcollection varsa)
      match /products/{productId} {
        allow read: if true;
        allow create, update: if request.auth != null
          && request.auth.uid == storeId;
        allow delete: if request.auth != null
          && request.auth.uid == storeId;
      }

      // Adres gönderimleri
      // - Herkes oluşturabilir (üye olmayanlar dahil, misafir müşteriler)
      // - Sadece mağaza sahibi okuyabilir ve silebilir
      match /addresses/{addressId} {
        allow read: if request.auth != null
          && request.auth.uid == storeId;
        allow create: if true;
        allow update: if false;
        allow delete: if request.auth != null
          && request.auth.uid == storeId;
      }
    }

    match /chats/{chatId} {
      allow read: if request.auth != null
        && (request.auth.uid in resource.data.participants
            || chatId == 'admin_' + request.auth.uid
            || 'butikbiz_admin' in resource.data.participants);
      allow create: if request.auth != null
        && (request.auth.uid in request.resource.data.participants
            || 'butikbiz_admin' in request.resource.data.participants)
        && request.resource.data.participants.size() == 2;
      allow update: if request.auth != null
        && (request.auth.uid in resource.data.participants
            || 'butikbiz_admin' in resource.data.participants);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && (request.resource.data.senderId == request.auth.uid
              || request.resource.data.senderId == 'butikbiz_admin')
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 5000;
        allow update: if request.auth != null;
        allow delete: if false;
      }
    }

    // Admin verileri - sadece admin okuyabilir/yazabilir
    // NOT: Admin uid'sini burada tanımlamanız gerekir
    // Şimdilik giriş yapan herkes okuyabilir, yazma için admin kontrolü yapılır
    match /admin/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Diğer tüm dökümanlar varsayılan olarak reddedilir
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
